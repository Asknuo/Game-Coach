# ── LLM (DeepSeek V4 Pro / OpenAI 兼容) ──
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Embedding (DeepSeek 暂无 Embedding，沿用 OpenAI) ──
# 如果同一个 Key 同时支持 Chat + Embedding，设为相同值
# 否则单独设置 EMBEDDING_API_KEY
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# ── 兼容旧变量（可选） ──
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Collector → Agent WebSocket ──
AGENT_WS_URL=ws://localhost:8000/ws/collector

# ── Collector polling interval (seconds) ──
POLL_INTERVAL=1.0
